# ── Obecné ────────────────────────────────────────────────────────────────────
APP_NAME=CloudSoundboard
ENVIRONMENT=development
DEBUG=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000","app://.","file://"]
BASE_URL=http://10.0.0.34:8000
# ── Databáze ──────────────────────────────────────────────────────────────────
# SQLite (výchozí pro vývoj)
DATABASE_URL=sqlite+aiosqlite:///./cloudsoundboard.db

# PostgreSQL (produkce)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cloudsoundboard

# ── Bezpečnost ────────────────────────────────────────────────────────────────
# Vygeneruj pomocí: openssl rand -hex 32
SECRET_KEY=4a2f8b9c1d0e3f5a7b9c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Soubory ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ── S3 (volitelné) ────────────────────────────────────────────────────────────
USE_S3=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1
# S3_BUCKET_NAME=

# ── Logování ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
